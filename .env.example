# Med admin-siden (/admin) kan du sette det meste fra nettleseren.
# Det eneste du MÅ sette som miljøvariabel er ADMIN_PASSWORD og SESSION_SECRET.
# Resten kan enten settes her (som oppstartsverdier) eller på admin-siden.

# ---- MÅ settes ----
# Passord for å komme inn på admin-siden (/admin).
ADMIN_PASSWORD=velg-et-sterkt-admin-passord
# Lang tilfeldig streng som signerer innloggings-cookien.
SESSION_SECRET=bytt-til-en-lang-tilfeldig-streng

# ---- Permanent lagring av innstillinger (anbefalt på Railway) ----
# Pek til en montert Volume slik at innstillinger overlever ny deploy.
SETTINGS_PATH=/data/settings.json

# ---- Kan settes her ELLER på admin-siden ----
# Datakilde: MCP-URL fra Regnskapsagent ("Kopier URL-en" i dashbordet deres).
# Gir tilgang til Tripletex-dataene – behandle som et passord.
REGNSKAPSAGENT_MCP_URL=
# Felles passord ansatte logger inn med.
DASHBOARD_PASSWORD=velg-et-passord
# Normal kapasitet per ansatt per uke (timer) – brukes til ledig-kapasitet.
WEEKLY_CAPACITY_HOURS=37.5
# Hvor ofte nettleseren henter ferske tall (sekunder).
REFRESH_SECONDS=60
# Hvor lenge data caches på serveren (millisekunder).
CACHE_TTL_MS=300000
# Firmanavn og forsidebilde (valgfritt – kan endres på admin-siden).
COMPANY_NAME=BYGG-KON
# HERO_IMAGE_URL=https://...

# PORT settes automatisk av Railway.
