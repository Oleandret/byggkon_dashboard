# ---- Tripletex API ----
# Hentes i Tripletex: Selskap > Vår tilgang / API-tilgang.
# Consumer-token får du fra Tripletex (eller via en integrasjonspartner).
TRIPLETEX_CONSUMER_TOKEN=din-consumer-token
# Employee-token genereres på din egen brukerprofil i Tripletex (API-tilgang).
TRIPLETEX_EMPLOYEE_TOKEN=din-employee-token

# Bruk test-miljøet mens du prøver ut (valgfritt):
# TRIPLETEX_BASE_URL=https://api-test.tripletex.tech/v2
# Produksjon (standard hvis utelatt):
# TRIPLETEX_BASE_URL=https://tripletex.no/v2

# ---- Innlogging for ansatte ----
# Felles passord alle ansatte bruker for å åpne dashbordet.
DASHBOARD_PASSWORD=velg-et-passord
# Lang tilfeldig streng som signerer innloggings-cookien.
SESSION_SECRET=bytt-til-en-lang-tilfeldig-streng

# ---- Valgfritt ----
# Hvor lenge tall caches i minnet (millisekunder). Standard 5 min.
CACHE_TTL_MS=300000
# Port settes automatisk av Railway. Lokalt brukes 3000.
# PORT=3000
